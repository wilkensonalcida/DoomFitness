{
  "manifest_version": 3,
  "name": "DoomFitness",
  "version": "1.0",
  "description": "Earn your scroll time with squats.",
  "permissions": ["storage", "alarms", "declarativeNetRequest"],
  "host_permissions": ["*://*.tiktok.com/*", "*://*.instagram.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "blocklist",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["lockscreen.html", "lib/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
