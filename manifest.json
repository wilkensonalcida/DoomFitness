{
  "manifest_version": 3,
  "name": "DoomFitness Blocker",
  "version": "1.0",
  "description": "Scroll too long and you have to do squats to get back in. Posture > dopamine.",

  "permissions": ["camera", "storage", "activeTab"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "DoomFitness",
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.tiktok.com/*",
        "*://*.instagram.com/*",
        "*://*.youtube.com/*",
        "*://*.reddit.com/*",
        "*://*.wikipedia.org/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["lock.html", "lock.js", "tf.min.js", "pose-detection.min.js"],
      "matches": [
        "*://*.tiktok.com/*",
        "*://*.instagram.com/*",
        "*://*.youtube.com/*",
        "*://*.reddit.com/*",
        "*://*.wikipedia.org/*"
      ]
    }
  ]
}
